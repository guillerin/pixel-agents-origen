{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Install All Dependencies",
			"type": "shell",
			"command": "yarn install",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"label": "Install Webview Dependencies",
			"type": "shell",
			"command": "npm install",
			"options": {
				"cwd": "${workspaceFolder}/apps/clients/vscode-extension/webview-ui"
			},
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"label": "Extension: Build",
			"type": "shell",
			"command": "yarn workspace @token-town/vscode-extension run build",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"label": "Extension: Watch",
			"type": "shell",
			"command": "yarn workspace @token-town/vscode-extension run watch",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": "build",
			"isBackground": true,
			"presentation": {
				"reveal": "never",
				"panel": "dedicated"
			},
			"problemMatcher": {
				"owner": "esbuild",
				"fileLocation": "absolute",
				"pattern": {
					"regexp": "✘ \\[ERROR\\] (.+?)\\n\\s+(.+?):(\\d+):(\\d+):",
					"message": 1,
					"file": 2,
					"line": 3,
					"column": 4
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "\\[watch\\] build started",
					"endsPattern": "\\[watch\\] build finished"
				}
			}
		},
		{
			"label": "Angular App: Dev",
			"type": "shell",
			"command": "yarn workspace @token-town/angular-app run dev",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"isBackground": true,
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"group": "frontend"
			},
			"problemMatcher": []
		},
		{
			"label": "Docker: Up",
			"type": "shell",
			"command": "docker compose -f infrastructure/dockers/development/docker-compose.yml up -d && docker compose -f infrastructure/dockers/development/docker-compose.yml exec postgres pg_isready -U postgres -d tokentown -q || echo 'Waiting for DB...'",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"group": "backend"
			},
			"problemMatcher": []
		},
		{
			"label": "Docker: Down",
			"type": "shell",
			"command": "yarn docker:down",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"label": "Go App: Dev",
			"type": "shell",
			"command": "yarn workspace @token-town/go-app run dev",
			"dependsOn": ["Docker: Up"],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"isBackground": true,
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"group": "backend"
			},
			"problemMatcher": []
		},
		{
			"label": "Deploy (interactive)",
			"type": "shell",
			"command": "npx tsx infrastructure/scripts/deploy.ts",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"focus": true
			},
			"problemMatcher": []
		},
		{
			"label": "Start: Frontend",
			"dependsOn": ["Angular App: Dev"],
			"problemMatcher": []
		},
		{
			"label": "Start: Backend",
			"dependsOn": ["Go App: Dev"],
			"problemMatcher": []
		},
		{
			"label": "Start: Client + Server",
			"dependsOn": ["Angular App: Dev", "Go App: Dev"],
			"dependsOrder": "parallel",
			"problemMatcher": [],
			"group": {
				"kind": "test",
				"isDefault": true
			}
		}
	]
}
