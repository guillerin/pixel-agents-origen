{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Install All Dependencies",
			"type": "shell",
			"command": "yarn install",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"label": "Install Webview Dependencies",
			"type": "shell",
			"command": "npm install",
			"options": {
				"cwd": "${workspaceFolder}/apps/clients/vscode-extension/webview-ui"
			},
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"label": "Extension: Build",
			"type": "shell",
			"command": "yarn workspace @token-town/vscode-extension run build",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"label": "Extension: Watch",
			"type": "shell",
			"command": "yarn workspace @token-town/vscode-extension run watch",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": "build",
			"isBackground": true,
			"presentation": {
				"reveal": "never",
				"panel": "dedicated"
			},
			"problemMatcher": {
				"owner": "esbuild",
				"fileLocation": "absolute",
				"pattern": {
					"regexp": "✘ \\[ERROR\\] (.+?)\\n\\s+(.+?):(\\d+):(\\d+):",
					"message": 1,
					"file": 2,
					"line": 3,
					"column": 4
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "\\[watch\\] build started",
					"endsPattern": "\\[watch\\] build finished"
				}
			}
		},
		{
			"label": "Admin Panel: Dev",
			"type": "shell",
			"command": "yarn workspace @token-town/admin-panel run dev",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"isBackground": true,
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			},
			"problemMatcher": []
		}
	]
}
