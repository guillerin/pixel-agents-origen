{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Run Extension",
			"type": "extensionHost",
			"request": "launch",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}/apps/clients/vscode-extension",
				"${workspaceFolder}/token-town.code-workspace"
			],
			"outFiles": [
				"${workspaceFolder}/apps/clients/vscode-extension/dist/**/*.js"
			],
			"preLaunchTask": "Extension: Build"
		}
	]
}
