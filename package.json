{
  "name": "token-town",
  "version": "1.1.1",
  "private": true,
  "workspaces": [
    "apps/clients/*",
    "apps/servers/*",
    "packages/*"
  ],
  "scripts": {
    "build": "yarn workspaces foreach -A --topological run build",
    "dev": "yarn workspaces foreach -A --parallel run dev",
    "lint": "yarn workspaces foreach -A run lint",
    "check-types": "yarn workspaces foreach -A run check-types",
    "clean": "yarn workspaces foreach -A run clean",
    "build:extension": "yarn workspace @token-town/vscode-extension run build",
    "watch:extension": "yarn workspace @token-town/vscode-extension run watch",
    "build:admin": "yarn workspace @token-town/angular-app run build",
    "dev:admin": "yarn workspace @token-town/angular-app run dev",
    "build:server": "yarn workspace @token-town/go-app run build",
    "dev:server": "yarn workspace @token-town/go-app run dev",
    "test:server": "yarn workspace @token-town/go-app run test",
    "docker:up": "docker compose -f infrastructure/dockers/development/docker-compose.yml up -d",
    "docker:down": "docker compose -f infrastructure/dockers/development/docker-compose.yml down",
    "docker:logs": "docker compose -f infrastructure/dockers/development/docker-compose.yml logs -f",
    "docker:reset": "docker compose -f infrastructure/dockers/development/docker-compose.yml down -v && docker compose -f infrastructure/dockers/development/docker-compose.yml up -d",
    "db:migrate": "cd infrastructure/dockers/development/scripts && ./migrate.sh up",
    "db:seed": "cd infrastructure/dockers/development/scripts && ./migrate.sh seed",
    "db:reset": "cd infrastructure/dockers/development/scripts && ./migrate.sh reset",
    "db:status": "cd infrastructure/dockers/development/scripts && ./migrate.sh status",
    "db:connect": "cd infrastructure/dockers/development/scripts && ./migrate.sh connect",
    "deploy": "npx tsx infrastructure/scripts/deploy.ts"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "engines": {
    "vscode": "^1.105.0"
  }
}
