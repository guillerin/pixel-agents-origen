{
  "name": "token-town",
  "version": "1.1.1",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "vscode": "^1.105.0"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --parallel",
